{% extends 'base.html.twig' %}

{% block body %}
<style>
    /* Estilos generales elegantes (TUS ESTILOS ORIGINALES INTACTOS) */
    body {
        background-color: #fcfbfa; /* Fondo general color crema muy suave, no blanco puro */
        color: #333333;
        font-family: 'Helvetica Neue', Arial, sans-serif;
    }
    .hero-section { 
        text-align: center; 
        padding: 60px 20px 40px 20px; 
        background-color: #fcfbfa;
    }
    .badge-gota {
        font-size: 1.5em;
        margin-bottom: 10px;
        opacity: 0.7;
    }
    .brand-title { 
        font-size: 3em; 
        font-weight: 300; /* Letra más fina y estilizada */
        letter-spacing: 4px;
        margin-bottom: 5px; 
        color: #222222;
        text-transform: uppercase;
    }
    /* Colores suaves para las iniciales */
    .brand-title .pink { color: #d4a3a9; font-weight: 400; }
    .brand-title .blue { color: #9bb7c4; font-weight: 400; }
    
    .brand-subtitle { 
        font-size: 1em; 
        color: #8e8e8e; 
        letter-spacing: 5px; 
        text-transform: uppercase; 
        margin-bottom: 25px; 
    }
    .intro-text { 
        max-width: 650px; 
        margin: 0 auto; 
        color: #666666; 
        line-height: 1.8; 
        font-size: 1.05em;
        font-weight: 300;
    }

    /* Tarjetas de Joyas Estilo Boutique */
    .joya-card {
        flex: 0 1 320px; 
        border: 1px solid #f0edf0; 
        padding: 0; 
        border-radius: 4px; 
        text-align: center; 
        background-color: #ffffff;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02); 
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .joya-card:hover {
        transform: translateY(-5px); 
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }
    .joya-img {
        width: 100%; 
        height: 280px; 
        object-fit: cover;
    }
    .joya-info {
        padding: 20px;
    }
    .joya-title {
        margin-bottom: 8px; 
        font-weight: 400; 
        font-size: 1.15em; 
        color: #333333;
        letter-spacing: 0.5px;
    }
    .joya-precio {
        color: #7e685a; 
        font-size: 1.2em; 
        font-weight: 400; 
        margin-bottom: 0px; /* Ajustado a 0 para un acabado limpio al final de la tarjeta */
    }
    
    /* Pequeños añadidos discretos para los nuevos datos */
    .joya-material {
        font-size: 0.8em;
        color: #a19286;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }
    .joya-descripcion {
        font-size: 0.85em;
        color: #777777;
        line-height: 1.5;
        margin-bottom: 15px;
        font-weight: 300;
        padding: 0 10px;
    }
    .main-footer {
        padding: 40px 20px;
        margin-top: 60px;
        border-top: 1px solid #f0edf0;
        text-align: center;
    }
</style>

<div class="container" style="max-width: 1200px; margin: 0 auto; padding-bottom: 60px;">
    <div class="hero-section">
        <div class="badge-gota">✨</div>
        <h1 class="brand-title">Di<span class="pink">ME</span><span class="blue">TU</span></h1>
        <div class="brand-subtitle">Joyas Maternales</div>
        
        <p class="intro-text">
            Transformamos tus recuerdos más puros en piezas eternas. 
            Especialistas en joyas biológicas únicas y artesanales hechas con todo el amor que tu historia merece.
        </p>
    </div>

    <!-- DECLARACIÓN DE TUS PRODUCTOS ACTUALIZADOS -->
    {% set joyas_manuales = [
        {
            'nombre': 'Colgante Inicial',
            'precio': '85',
            'imagen': 'colgante_inicial.jpeg',
            'material': 'Plata de Ley 925',
            'detalles': 'Colgante inicial rellenable de leche materna, cordón umbilical, arena...'
        },
        {
            'nombre': 'Colgante Nombre',
            'precio': '135',
            'imagen': 'colgante_nombre.jpeg',
            'material': 'Plata de Ley 925',
            'detalles': 'Nombre caligrafiado a mano con detalle de estrella o corazón calada lateral.'
        },
        {
            'nombre': 'Colgante Bala',
            'precio': '75',
            'imagen': 'colgante_bala.jpeg',
            'material': 'Acero inoxidable y resina con muestra biológica',
            'detalles': 'Cápsula ideal para incorporar cordón umbilical, leche materna, ceniza de cremación, arena de la playa....'
        },
        {
            'nombre': 'Colgante Corazón',
            'precio': '85',
            'imagen': 'colgante_corazon4.jpeg',
            'material': 'Plata de Ley 925',
            'detalles': 'Colgante con forma de corazón rellenable de leche materna, cordón umbilical, arena...'
        },
        {
            'nombre': 'Colgante estrella',
            'precio': '85',
            'imagen': 'ColganteEstrella.jpg',
            'material': 'Plata de Ley 925',
            'detalles': 'Colgante con forma de Estrella rellenable de leche materna, cordón umbilical, arena...'
        },
        {
            'nombre': 'Alianza',
            'precio': '190',
            'imagen': 'Alianza.JPG',
            'material': 'Plata de Ley 925',
            'detalles': 'Alianza rellenable de leche materna, cordón umbilical, arena...'
        },
        {
            'nombre': 'Charm',
            'precio': '85',
            'imagen': 'Charm.jpg',
            'material': 'Plata de Ley 925',
            'detalles': 'Charm tradicional de leche materna, cordón umbilical, flores secas, arena, diente de leche..'
        }
    ] %}

    <!-- Rejilla de productos limpia -->
    <div class="joyas-grid" style="display: flex; flex-wrap: wrap; gap: 30px; justify-content: center; padding: 20px;">
        {% for joya in joyas_manuales %}
            <div class="joya-card">
                <!-- Foto con tus proporciones -->
                <img src="{{ asset('images/joyas/' ~ joya.imagen) }}" alt="{{ joya.nombre }}" class="joya-img">
                
                <div class="joya-info">
                    <!-- 1. Nombre de la joya -->
                    <h5 class="joya-title">{{ joya.nombre }}</h5>
                    
                    <!-- 2. Material empleado -->
                    <div class="joya-material">💎 {{ joya.material }}</div>
                    
                    <!-- 3. Detalles del producto -->
                    <p class="joya-descripcion">{{ joya.detalles }}</p>
                    
                    <!-- 4. Precio elegante -->
                    <p class="joya-precio">{{ joya.precio }} €</p>
                </div>
            </div>
        {% else %}
            <div style="text-align: center; margin-top: 20px; width: 100%;">
                <p style="color: #999; font-style: italic; font-weight: 300;">Aún no hay joyas disponibles en la colección.</p>
            </div>
        {% endfor %}
    </div>

</div>

<!-- DATOS DE CONTACTO DISCRETOS AL FINAL -->
<footer class="main-footer">
    <p style="margin-bottom: 8px; font-size: 0.85em; color: #8e8e8e; letter-spacing: 1px;">DIMETU JOYAS MATERNALES © 2026</p>
    <p style="font-size: 0.8em; color: #bca089;">Contacto: infodimetu@gmail.com | 661429213 | Instagram: @dimetu_joyas_maternales</p>
</footer>
{% endblock %}


